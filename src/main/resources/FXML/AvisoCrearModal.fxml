<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="550.0" styleClass="modal-root" stylesheets="@../CSS/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dmontoro.fixitapi.controllers.controllersfxml.AvisoCrearModalController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" prefHeight="460.0" prefWidth="510.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="modal-title" text="Nuevo Aviso" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#cerrarModal" styleClass="btn-close-modal" text="✕" />
                    </children>
                </HBox>

                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="240.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="240.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="20.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="20.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label styleClass="modal-label" text="Cliente" />
                        <ComboBox fx:id="comboCliente" prefWidth="500.0" promptText="Selecciona un cliente" styleClass="modal-combo" GridPane.rowIndex="1" />

                        <Label styleClass="modal-label" text="Técnico" GridPane.columnIndex="1" />
                        <ComboBox fx:id="comboTecnico" prefWidth="500.0" promptText="Asignar técnico" styleClass="modal-combo" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="modal-label" text="Categoría" GridPane.rowIndex="2" />
                        <ComboBox fx:id="comboCategoria" prefWidth="500.0" promptText="Tipo de reparación" styleClass="modal-combo" GridPane.rowIndex="3" />

                        <Label styleClass="modal-label" text="Prioridad" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <ComboBox fx:id="comboPrioridad" prefWidth="500.0" promptText="Nivel de prioridad" styleClass="modal-combo" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="modal-label" text="Descripción del Problema" />
                        <TextArea fx:id="txtDescripcion" prefHeight="120.0" promptText="Describe la avería o problema..." styleClass="modal-value" wrapText="true" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <HBox alignment="BOTTOM_RIGHT" spacing="15.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#cerrarModal" styleClass="btn-cancelar" text="Cancelar" />
                        <Button mnemonicParsing="false" onAction="#crearAviso" styleClass="btn-crear" text="Crear Aviso" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>