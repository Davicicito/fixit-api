<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<?import javafx.scene.layout.AnchorPane?>
<BorderPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@../CSS/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dmontoro.fixitapi.controllers.controllersfxml.InventarioController">

    <left>
        <VBox prefWidth="260.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label styleClass="sidebar-logo-icon" text="🔧" />
                        <VBox alignment="CENTER_LEFT">
                            <children>
                                <HBox>
                                    <children>
                                        <Label styleClass="logo-text-fix" text="Fix" />
                                        <Label styleClass="logo-text-it" text="It" />
                                    </children>
                                </HBox>
                                <Label styleClass="logo-subtext" text="Panel de Control" />
                            </children>
                        </VBox>
                    </children>
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </HBox>

                <VBox spacing="10.0" styleClass="menu-box">
                    <children>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#irADashboard" spacing="12.0" styleClass="menu-item">
                            <SVGPath content="M3 4a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1zm11 0a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-5a1 1 0 0 1-1-1zm0 9a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1h-5a1 1 0 0 1-1-1zm-11 4a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Dashboard" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" onMouseClicked="#irAGestionAvisos" spacing="12.0" styleClass="menu-item">
                            <SVGPath content="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2 M15 2H9a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z M12 11h4 M12 16h4 M8 11h.01 M8 16h.01" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Gestión de Avisos" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="menu-item-active">
                            <SVGPath content="M16.5 9.4l-9-5.19 M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96L12 12.01l8.73-5.05 M12 22.08V12" styleClass="menu-icon-active" />
                            <Label styleClass="menu-text-active" text="Inventario" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" onMouseClicked="#irATecnicos" spacing="12.0" styleClass="menu-item">
                            <SVGPath content="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M22 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Técnicos" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="menu-item">
                            <SVGPath content="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18 M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2 M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2 M10 6h4 M10 10h4 M10 14h4 M10 18h4" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Clientes" />
                        </HBox>
                    </children>
                    <VBox.margin><Insets top="30.0" /></VBox.margin>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="15.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="user-profile-box">
                            <children>
                                <Label fx:id="lblAvatar" styleClass="avatar-circle" text="DM" />
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="lblNombreUsuario" styleClass="user-name" text="Cargando..." />
                                        <Label fx:id="lblRolUsuario" styleClass="user-role" text="..." />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Label onMouseClicked="#cerrarSesion" styleClass="logout-btn" text="↳ Cerrar Sesión" />
                    </children>
                </VBox>
            </children>
            <padding><Insets bottom="30.0" left="25.0" right="25.0" top="30.0" /></padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="25.0" styleClass="main-content" BorderPane.alignment="CENTER">
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
            <children>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="header-title" text="Inventario de Materiales" />
                                <Label styleClass="header-subtitle" text="Gestiona el stock y los precios" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#abrirModalCrearMaterial" styleClass="btn-green" text="+  Añadir Material" />
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <AnchorPane styleClass="kpi-solid-card, bg-solid-blue" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <Label styleClass="kpi-solid-title" text="Total Materiales" />
                                        <Label fx:id="lblTotalCard" styleClass="kpi-solid-number" text="0" />
                                    </children>
                                </VBox>
                                <SVGPath content="M16.5 9.4l-9-5.19 M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96L12 12.01l8.73-5.05 M12 22.08V12" scaleX="2.0" scaleY="2.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="25.0" styleClass="kpi-watermark-icon" />
                            </children>
                        </AnchorPane>

                        <AnchorPane styleClass="kpi-solid-card, bg-solid-orange" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <Label styleClass="kpi-solid-title" text="Stock Bajo" />
                                        <Label fx:id="lblStockBajoCard" styleClass="kpi-solid-number" text="0" />
                                    </children>
                                </VBox>
                                <SVGPath content="M21.73 18l-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z M12 9v4 M12 17h.01" scaleX="2.0" scaleY="2.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="25.0" styleClass="kpi-watermark-icon" />
                            </children>
                        </AnchorPane>

                        <AnchorPane styleClass="kpi-solid-card, bg-solid-green" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <Label styleClass="kpi-solid-title" text="Stock OK" />
                                        <Label fx:id="lblStockOkCard" styleClass="kpi-solid-number" text="0" />
                                    </children>
                                </VBox>
                                <SVGPath content="M 12 2 a 10 10 0 1 0 0 20 a 10 10 0 1 0 0 -20 M 9 12 l 2 2 l 4 -4" scaleX="2.0" scaleY="2.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="25.0" styleClass="kpi-watermark-icon" />
                            </children>
                        </AnchorPane>

                        <AnchorPane styleClass="kpi-solid-card, bg-solid-purple" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <Label styleClass="kpi-solid-title" text="Valor Total" />
                                        <Label fx:id="lblValorTotalCard" styleClass="kpi-solid-number" text="€0" />
                                    </children>
                                </VBox>
                                <SVGPath content="M22 17L13.5 8.5 8.5 13.5 2 7 M16 17h6v-6" scaleX="2.0" scaleY="2.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="25.0" styleClass="kpi-watermark-icon" />
                            </children>
                        </AnchorPane>
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="filter-bar">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="🔍" textFill="#94A3B8" />
                                <TextField fx:id="txtBuscar" promptText="Buscar material o categoría..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tablaMateriales" styleClass="custom-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMaterial" prefWidth="250.0" text="Material" />
                        <TableColumn fx:id="colCategoria" prefWidth="150.0" text="Categoría" />
                        <TableColumn fx:id="colStock" prefWidth="100.0" style="-fx-font-weight: bold;" text="Stock" />
                        <TableColumn fx:id="colStockMin" prefWidth="100.0" text="Stock Mínimo" />
                        <TableColumn fx:id="colUnidad" prefWidth="100.0" text="Unidad" />
                        <TableColumn fx:id="colPrecio" prefWidth="100.0" text="Precio" />
                        <TableColumn fx:id="colValorTotal" prefWidth="120.0" style="-fx-text-fill: #3B82F6; -fx-font-weight: bold;" text="Valor Total" />
                        <TableColumn fx:id="colEstado" prefWidth="130.0" text="Estado" />
                        <TableColumn fx:id="colAcciones" prefWidth="100.0" text="Acciones" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </children>
        </VBox>
    </center>
</BorderPane>