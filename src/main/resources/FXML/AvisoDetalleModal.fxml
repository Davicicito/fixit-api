<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.shape.SVGPath?>
<AnchorPane prefHeight="530.0" prefWidth="500.0" styleClass="modal-root" stylesheets="@../CSS/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dmontoro.fixitapi.controllers.controllersfxml.AvisoDetalleModalController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" prefHeight="490.0" prefWidth="460.0" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label fx:id="lblTituloFormulario" styleClass="modal-title" text="Detalles del Aviso #00" />

                <GridPane vgap="15.0" hgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label styleClass="modal-label" text="Cliente:" />
                        <Label fx:id="lblCliente" prefWidth="350.0" styleClass="modal-value" text="Nombre del Cliente" GridPane.columnIndex="1" />

                        <Label styleClass="modal-label" text="Técnico:" GridPane.rowIndex="1" />
                        <Label fx:id="lblTecnico" prefWidth="350.0" styleClass="modal-value" text="Nombre del Técnico" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="modal-label" text="Categoría:" GridPane.rowIndex="2" />
                        <Label fx:id="lblCategoria" prefWidth="350.0" styleClass="modal-value" text="Fontanería" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label styleClass="modal-label" text="Prioridad:" GridPane.rowIndex="3" />
                        <Label fx:id="lblPrioridad" prefWidth="350.0" styleClass="modal-value" text="MEDIA" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label styleClass="modal-label" text="Descripción:" GridPane.rowIndex="4" />
                        <TextArea fx:id="txtDescripcion" editable="false" prefHeight="200.0" prefWidth="200.0" styleClass="modal-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <Label styleClass="modal-label" text="Estado Actual:" GridPane.rowIndex="5" />
                        <ComboBox fx:id="comboEstado" prefWidth="350.0" styleClass="modal-combo" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>

                <Button fx:id="btnVerFoto" onAction="#verFotoAveria" styleClass="btn-secundario" text=" Ver Foto">
                    <graphic>
                        <SVGPath content="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z M12 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"
                                 styleClass="icon-lucide" style="-fx-stroke: #475569;" />
                    </graphic>
                </Button>

                <Button fx:id="btnVerFirma" onAction="#verFirmaCliente" styleClass="btn-secundario" text=" Ver Firma">
                    <graphic>
                        <SVGPath content="M12 20h9 M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"
                                 styleClass="icon-lucide" style="-fx-stroke: #475569;" />
                    </graphic>
                </Button>

                <HBox alignment="BOTTOM_RIGHT" prefHeight="50.0" prefWidth="200.0" spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button mnemonicParsing="false" onAction="#cerrarModal" styleClass="btn-cancelar" text="Cancelar" />
                        <Button mnemonicParsing="false" onAction="#guardarCambios" styleClass="btn-guardar" text="Guardar Cambios" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>